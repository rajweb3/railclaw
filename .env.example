# ===========================================
# Railclaw Environment Variables
# Copy to .env and fill in real values
# ===========================================

# --- Telegram Bot Tokens (from @BotFather) ---
TELEGRAM_BOT_TOKEN_OWNER=your-owner-bot-token-here
TELEGRAM_BOT_TOKEN_PRODUCT=your-product-bot-token-here

# --- AI Provider (OpenRouter — free models available) ---
# Get key from https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# --- Anthropic API Key (for Claude) — not needed if using OpenRouter ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Wallet Encryption ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=your-64-char-hex-key-here

# --- Blockchain RPCs ---
# Use your own Alchemy/Infura/QuickNode endpoints for production
RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_SOLANA=https://api.mainnet-beta.solana.com

# --- Cross-Chain Bridge (Across Protocol) ---
# Only required if cross_chain.bridge.enabled = true in BOUNDARY.md

# SOL dispenser wallet — funds temp wallets with ~0.005 SOL for depositV3 tx fees
# Generate with: npx tsx shared/scripts/generate-sol-dispenser.ts
# That prints the key below AND a Solana address — send at least 0.1 SOL to that address
SOLANA_SOL_DISPENSER_KEY=

# Optional fee tuning — defaults are conservative and safe to leave as-is
# ACROSS_RELAY_FEE_PCT=0.0012    # 0.12% of amount (LP fee ~0.04% + gas buffer)
# ACROSS_MIN_FEE_BUFFER=0.50     # Minimum $0.50 fee regardless of percentage
# SOLANA_FUND_LAMPORTS=1000000   # SOL to send to each temp wallet (default 0.001 SOL ~$0.05)

# --- Payment Links ---
# Use your EC2 public IP for now. Replace with domain later.
# Find your public IP: curl -s http://checkip.amazonaws.com
PAYMENT_LINK_BASE_URL=http://YOUR_EC2_PUBLIC_IP:3000
PAYMENT_EXPIRY_HOURS=24

# --- Transaction Monitoring ---
TX_POLL_INTERVAL_MS=15000
TX_REQUIRED_CONFIRMATIONS=20
TX_MONITOR_TIMEOUT_MS=3600000

# --- Dynamic Payment Rails (demo/) ---
# Required for Circle Gateway nanopayments
# Seller: EVM wallet that receives USDC from nanopayments
CIRCLE_SELLER_ADDRESS=0xYOUR_SELLER_WALLET_ADDRESS
# Buyer: EVM private key for the agent's Circle Gateway wallet (funded with testnet USDC)
# Get testnet USDC from Circle Faucet: https://faucet.circle.com
CIRCLE_BUYER_PRIVATE_KEY=0xYOUR_BUYER_PRIVATE_KEY

# AgentCard Visa — install CLI: npm install -g agent-cards && agent-cards signup
# No env vars needed — card_id is set in the Business panel UI (or BOUNDARY.md)

# OpenClaw gateway auth token — auto-generated by setup.sh if not set
# Used by the demo UI to proxy requests to OpenClaw agents
OPENCLAW_GATEWAY_TOKEN=

# Optional: custom port for the demo server (default: 3100)
# DEMO_PORT=3100
